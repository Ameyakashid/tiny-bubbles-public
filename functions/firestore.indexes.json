{
  "__comment": "firestore.indexes.json — w1 M1.2 (§3.2 query indexes). Parent dashboard reads activity newest-first filtered by kind; transcript review pages by session; alert triage filters by status. Native TTL policies (expiresAt on activity/transcripts/alerts) are configured OUT-OF-BAND via `gcloud firestore fields ttls update` — see functions/docs/RULES-REVIEW.md.",
  "indexes": [
    {
      "collectionGroup": "activity",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "kind", "order": "ASCENDING" },
        { "fieldPath": "at", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "transcripts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sessionId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "transcripts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "flagged", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "alerts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "alerts",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "reEscalatedAt", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
