{
  "expo": {
    "name": "Tiny Bubbles",
    "slug": "tiny-bubbles",
    "version": "1.0.0",
    "scheme": "tinybubbles",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tinybubbles.app",
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "package": "com.tinybubbles.app",
      "allowBackup": false,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F0FBFF"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#36C5F0"
        }
      ],
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Tiny Bubbles can take an optional photo so a grown-up can confirm a chore is done. Photos stay on this device and are never uploaded.",
          "photosPermission": "Tiny Bubbles can attach an optional photo so a grown-up can confirm a chore is done. Photos stay on this device and are never uploaded."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
