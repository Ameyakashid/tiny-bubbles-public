{
  "expo": {
    "name": "Tiny Bubbles Parent",
    "slug": "tiny-bubbles-parent",
    "version": "0.1.0",
    "scheme": "tinybubblesparent",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tinybubbles.parent"
    },
    "android": {
      "package": "com.tinybubbles.parent",
      "allowBackup": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
